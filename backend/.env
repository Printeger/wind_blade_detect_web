# FastAPI service
APP_NAME=Wind Defect Detection API
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS
# 正式部署时改成你的 GitHub Pages 地址，例如：
# CORS_ALLOW_ORIGINS=https://yourname.github.io
CORS_ALLOW_ORIGINS=*

# Model backend
# mock: 演示模式，不依赖真实模型
# ultralytics: 使用 YOLO .pt 模型推理
MODEL_BACKEND=mock
MODEL_PATH=weights/best.pt
DEFAULT_MODEL_NAME=baseline-yolo

# Storage
UPLOAD_DIR=data/uploads
OUTPUT_DIR=data/outputs

# Batch
MAX_BATCH_FILES=200
