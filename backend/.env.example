# FastAPI service
APP_NAME=Wind Defect Detection API
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS
# 正式部署时改成你的 GitHub Pages 地址，例如：
# CORS_ALLOW_ORIGINS=https://your-pages-origin.example.com
CORS_ALLOW_ORIGINS=*

# Model backend
# mock: 演示模式，不依赖真实模型
# ultralytics: 使用 YOLO .pt 模型推理
# roboflow: 使用 Roboflow 托管模型推理
MODEL_BACKEND=mock
MODEL_PATH=weights/best.pt
AUTO_UPDATE_MODEL=false
MODEL_SEARCH_GLOB=
DEFAULT_MODEL_NAME=baseline-yolo

# Roboflow
ROBOFLOW_API_URL=https://serverless.roboflow.com
ROBOFLOW_API_KEY=
ROBOFLOW_MODEL_ID=

# Storage
UPLOAD_DIR=data/uploads
OUTPUT_DIR=data/outputs

# Batch
MAX_BATCH_FILES=200
